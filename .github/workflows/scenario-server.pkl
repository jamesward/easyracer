// pkl eval --format yaml -o scenario-server.yaml scenario-server.pkl

amends "package://pkg.pkl-lang.org/github.com/jamesward/pklgha/pklgha@0.0.25#/GitHubAction.pkl"
import "package://pkg.pkl-lang.org/github.com/jamesward/pklgha/pklgha@0.0.25#/GitHubAction.pkl"

on {
  local thesePaths = new Listing<String> {
    "scenario-server/**"
    ".github/workflows/scenario-server.yaml"
  }

  push {
    paths = thesePaths
  }
  pull_request {
    paths = thesePaths
  }
}

local javaVersion = "25"

local function sbtDockerBuildPushJob(arch: String): GitHubAction.Job = new {
  `runs-on` = if (arch == "amd64") "ubuntu-24.04" else "ubuntu-24.04-arm"
  needs = "test"
  steps {
    new { uses = "actions/checkout@v5" }
    GitHubAction.Java.setupJava(null, javaVersion, "sbt")
    new { uses = "sbt/setup-sbt@v1" }
    new {
      uses = "docker/login-action@v3"
      `with` {
        ["registry"] = "ghcr.io"
        ["username"] = "${{ github.actor }}"
        ["password"] = "${{ secrets.GITHUB_TOKEN }}"
      }
    }
    new {
      run = "sbt Docker/publishLocal"
      `working-directory` = "scenario-server"
      env {
        ["DOCKER_IMAGE"] = "ghcr.io/${{ github.repository }}"
        ["DOCKER_TAG"] = "${{ github.sha }}-\(arch)"
      }
    }
    new {
      `if` = "${{ github.actor == github.repository_owner }}"
      run = new Listing {
        "docker push ghcr.io/${{ github.repository }}:${{ github.sha }}-\(arch)"
        #"if [ "${{ github.ref }}" = "refs/heads/main" ]; then"#
        "  docker tag ghcr.io/${{ github.repository }}:${{ github.sha }}-\(arch) ghcr.io/${{ github.repository }}:latest-\(arch)"
        "  docker push ghcr.io/${{ github.repository }}:latest-\(arch)"
        "fi"
      }.toList().join("\n")
    }
  }
}

jobs {
  ["test"] = GitHubAction.Scala.sbtTestJob(null, "scenario-server", javaVersion)

  ["build-and-push-amd64"] = sbtDockerBuildPushJob("amd64")
  ["build-and-push-aarch64"] = sbtDockerBuildPushJob("aarch64")

  ["create-manifests"] = (GitHubAction.Docker.create("ghcr.io/${{ github.repository }}:latest", new Listing {
    "ghcr.io/${{ github.repository }}:latest-amd64"
    "ghcr.io/${{ github.repository }}:latest-aarch64"
  })) {
    `runs-on` = "ubuntu-24.04"
    `if` = "${{ github.actor == github.repository_owner && github.ref == 'refs/heads/main'}}"
    needs = new Listing {
      "build-and-push-amd64"
      "build-and-push-aarch64"
    }
  }
}
